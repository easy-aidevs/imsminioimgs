# ============================================
# MinIO 配置
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false

# 业务图片所在的桶（扫描器读取的桶）
MINIO_BUCKET_NAME=images

# 隔离桶：违规图片会被移到这里；URL 失效=用户无法访问。
# 该桶应配置为不公开。不存在时工具会自动创建。
QUARANTINE_BUCKET_NAME=quarantine

# ============================================
# MySQL 配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=image_security

# ============================================
# 腾讯云 IMS 配置（必填）
# ============================================
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here
TENCENT_REGION=ap-guangzhou

# ============================================
# 扫描参数（可选）
# ============================================
HASH_SIZE=8
SCAN_PREFIX=
FORCE_RESCAN=false
# SCAN_LIMIT=100      # 仅扫描前 N 张，用于测试

# ============================================
# Docker 网络模式
# ============================================
# host：容器共享宿主机网络，可访问 localhost
# bridge：需用宿主机 IP 访问外部服务
DOCKER_NETWORK_MODE=host
