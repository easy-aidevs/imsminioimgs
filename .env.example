# ============================================
# 独立扫描器模式 - 环境变量配置
# 使用外部MySQL和MinIO服务
# ============================================

# ============================================
# MinIO配置（外部服务）
# ============================================
# MinIO服务器地址
# Docker host网络模式: localhost:9000
# Docker bridge网络模式: 宿主机IP或MinIO服务地址
MINIO_ENDPOINT=localhost:9000

MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false
MINIO_BUCKET_NAME=images

# ============================================
# MySQL配置（外部服务）
# ============================================
# MySQL服务器地址
# Docker host网络模式: localhost
# Docker bridge网络模式: 宿主机IP或MySQL服务地址
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=image_security

# ============================================
# 腾讯云IMS配置（必须填写）
# ============================================
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here
TENCENT_REGION=ap-guangzhou

# ============================================
# 扫描配置
# ============================================
HASH_SIZE=8
SCAN_PREFIX=
FORCE_RESCAN=false
# SCAN_LIMIT=100  # 取消注释以限制扫描数量

# ============================================
# 特征缓存配置（性能优化）
# ============================================
# 是否启用特征缓存（默认: true）
CACHE_ENABLED=true

# 缓存策略: lru / full / none
# - lru: 只缓存最近的N个特征（推荐，适合大规模）
# - full: 缓存所有违规图片的特征（适合小规模）
# - none: 禁用缓存，直接查询数据库
CACHE_STRATEGY=lru

# LRU缓存最大特征数（默认: 10000）
# 仅当 CACHE_STRATEGY=lru 时生效
CACHE_MAX_SIZE=100000

# ============================================
# Docker网络配置
# ============================================
# host模式: 容器共享宿主机网络，可直接访问localhost
# bridge模式: 需要使用宿主机IP或外部服务地址
DOCKER_NETWORK_MODE=host
